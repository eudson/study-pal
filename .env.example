# StudyPal — environment template.
# Copy to `.env` (gitignored) and fill in real values:  cp .env.example .env
# NEVER commit .env. Secrets live only here (ARCHITECTURE.md §6).
#
# `make dev` does NOT need any of this — the docker stack uses a throwaway local
# Postgres. These values are for pointing migrations / the app at real Supabase.

# --- Postgres (Supabase) ------------------------------------------------------
# DIRECT connection (port 5432).  Supabase → Project Settings → Database →
# Connection string → "Direct connection".
#   NOTE: this host (db.<ref>.supabase.co) is IPv6-only — unreachable from
#   IPv4-only networks. `make migrate` therefore prefers STUDYPAL_DB_DSN (the
#   session pooler) below. To force the direct connection from an IPv6-capable
#   host, run `MIGRATE_DSN=$DB_DSN make migrate` (or enable Supabase's IPv4 add-on).
DB_DSN=postgresql://postgres:<DB_PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres

# SESSION pooler (port 5432, session mode) — used by the app request path AND,
# by default, by `make migrate` (IPv4-reachable, DDL-capable, same owner role).
#   Survives our per-request `SET ROLE authenticated`. Do NOT use the :6543
#   transaction pooler here — it drops session state and breaks RLS identity.
STUDYPAL_DB_DSN=postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-0-<REGION>.pooler.supabase.com:5432/postgres

# --- Claude (PR-2, generation) ------------------------------------------------
# Leave blank until wiring live generation.
STUDYPAL_ANTHROPIC_API_KEY=

# --- Auth (PR-2, JWT verification) --------------------------------------------
# From Supabase → Project Settings → API. Prefer asymmetric (JWKS) verification.
# STUDYPAL_SUPABASE_JWKS_URL=https://<PROJECT_REF>.supabase.co/auth/v1/.well-known/jwks.json
# STUDYPAL_SUPABASE_JWT_ISS=https://<PROJECT_REF>.supabase.co/auth/v1
# STUDYPAL_SUPABASE_JWT_AUD=authenticated
