*.pyc
.venv/
node_modules/
web/dist/
.DS_Store
fixtures/**/inputs/*.jpg
fixtures/**/inputs/*.png
fixtures/**/inputs/*.pdf
fixtures/**/answers/*.jpg
fixtures/**/answers/*.png
fixtures/**/answers/*.pdf
