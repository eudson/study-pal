# StudyPal web — environment template.
# Copy to `.env` (gitignored) and fill in real values:  cp .env.example .env
# Only VITE_-prefixed vars are exposed to the browser bundle — never put secrets
# here. The Supabase URL + anon key are public, project-specific values.

# Supabase project — Project Settings → API.
VITE_SUPABASE_URL=https://<PROJECT_REF>.supabase.co
VITE_SUPABASE_ANON_KEY=<ANON_PUBLIC_KEY>

# API base URL. Leave unset to use same-origin (Vite dev proxy / reverse proxy).
# VITE_API_BASE_URL=
